{
  "manifest_version": 3,
  "name": "Litmus",
  "version": "0.2.4",
  "description": "Flags AI-generated posts in the LinkedIn feed",

  "background": { "service_worker": "background.js" },

  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.gptzero.me/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/feed/*",
        "https://www.linkedin.com/in/*"
      ],
      "run_at": "document_idle",
      "js": [
        "config.js",
        "selectors.js",
        "cache.js",
        "extractor.js",
        "author-stats.js",
        "auto-hidden.js",
        "dev-log.js",
        "ui.js",
        "blacklist.js",
        "action-dispatcher.js",
        "observer.js",
        "content.js"
      ]
    }
  ],

  "action": {
    "default_popup": "popup/popup.html"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
